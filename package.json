{
  "name": "foundry-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Phase 1 runtime control spine for The Foundry.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "example": "npm.cmd run build && node dist/runtime/examples/run-example.js",
    "failure-example": "npm.cmd run build && node dist/runtime/examples/run-failure-example.js",
    "foundry": "npm.cmd run build && node dist/runtime/examples/run-foundry.js",
    "validate-workers": "npm.cmd run build && node dist/runtime/examples/validate-worker-artifacts.js",
    "validate-run-package": "npm.cmd run build && node dist/runtime/examples/validate-run-package.js",
    "validate-codex-skills": "npm.cmd run build && node dist/runtime/examples/validate-codex-skill-bundles.js",
    "validate-citadel-boundary": "npm.cmd run build && node dist/runtime/examples/validate-citadel-boundary.js"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.2"
  }
}
