{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foundry.run-package.v1",
  "title": "Foundry Run Package v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema",
    "missionId",
    "packetId",
    "projectSlug",
    "runId",
    "packageRoot",
    "objective",
    "templateId",
    "consequenceTier",
    "productionProfile",
    "deploymentTarget",
    "handoffDirective",
    "workerSpecPaths",
    "codexSkillBundlePaths",
    "failurePathReportPath",
    "scribeReportPath",
    "hashManifestPath",
    "includedDirectories",
    "includedFiles"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schema": { "const": "foundry.run-package.v1" },
    "missionId": { "type": "string", "minLength": 1 },
    "packetId": { "type": "string", "minLength": 1 },
    "projectSlug": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "packageRoot": { "const": "." },
    "objective": { "type": "string", "minLength": 1 },
    "templateId": {
      "enum": ["saas-build", "rapid-prototype", "verification-heavy", "creative-development"]
    },
    "consequenceTier": {
      "enum": ["trivial", "routine", "important", "critical"]
    },
    "productionProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "evidenceLevel", "retentionPolicy", "manifestStrategy"],
      "properties": {
        "mode": { "enum": ["prototype", "production"] },
        "evidenceLevel": { "type": "string", "minLength": 1 },
        "retentionPolicy": { "type": "string", "minLength": 1 },
        "manifestStrategy": { "type": "string", "minLength": 1 }
      }
    },
    "deploymentTarget": {
      "enum": ["worker-spec-only", "persona-only-artifacts", "codex-skill", "local-agent-manifest"]
    },
    "handoffDirective": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recipientType",
        "mode",
        "packageScope",
        "operatorDestinationPolicy",
        "rationale"
      ],
      "properties": {
        "recipientType": { "enum": ["operator", "agent", "skill"] },
        "mode": { "enum": ["operator-delivery", "package-reference"] },
        "packageScope": { "const": "run-package" },
        "operatorDestinationPolicy": { "enum": ["choose-at-return", "not-applicable"] },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "workerManifestPath": { "type": "string", "minLength": 1 },
    "workerSpecPaths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "codexSkillBundlePaths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "attestationPath": { "type": "string", "minLength": 1 },
    "executionEvidencePath": { "type": "string", "minLength": 1 },
    "critiqueReportPath": { "type": "string", "minLength": 1 },
    "auditReportPath": { "type": "string", "minLength": 1 },
    "failurePathReportPath": { "type": "string", "minLength": 1 },
    "scribeReportPath": { "type": "string", "minLength": 1 },
    "hashManifestPath": { "type": "string", "minLength": 1 },
    "signaturePath": { "type": "string", "minLength": 1 },
    "includedDirectories": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "includedFiles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
